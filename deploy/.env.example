# ===== Orchestrator =====
APP_ENV=dev
APP_PORT=8000
SECRET_KEY=change-me-in-prod
JWT_SECRET=change-me-in-prod
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ===== Database =====
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=zhiyou
POSTGRES_PASSWORD=zhiyou_pwd
POSTGRES_DB=zhiyou

REDIS_URL=redis://redis:6379/0

NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4j_pwd

# ===== Dify =====
DIFY_BASE_URL=http://dify-api:5001/v1
DIFY_API_KEY=your-dify-api-key-here
# 知识库（Datasets）：在 Dify 后台「知识库」详情页的 URL 中可见 dataset id；
# DIFY_DATASET_API_KEY 单独申请（设置 → API 访问 → 知识库 API Key）。
# 配置后 /api/admin/knowledge/upload 会自动 create_by_file 入库。
DIFY_DATASET_ID=
DIFY_DATASET_API_KEY=

# ===== ASR (FunASR) =====
ASR_BASE_URL=http://funasr:10095

# ===== TTS (CosyVoice2) =====
TTS_BASE_URL=http://cosyvoice:8001
TTS_DEFAULT_VOICE=guide_female_01
# TTS 二级降级链（Tier-2）：edge=微软 Edge TTS（免费）| fish=Fish Audio API | none=禁用
TTS_SECONDARY_PROVIDER=edge
# Fish Audio（TTS_SECONDARY_PROVIDER=fish 时填写）
FISH_API_KEY=
FISH_VOICE_ID=

# ===== LLM (for sentiment / suggestion / KG extraction) =====
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-plus

# ===== CORS =====
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175
